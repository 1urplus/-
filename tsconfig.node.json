{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "outDir": "dist-electron",
    "skipLibCheck": true,
    "strict": true,
    "composite": true
  },
  "include": ["electron", "vite.config.ts"]
}
